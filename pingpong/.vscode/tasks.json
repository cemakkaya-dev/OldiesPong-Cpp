{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ping_pong",
            "type": "shell",
            "command": "g++",
            "args": [
                "-o", "pong",
                "main.cpp",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-lSDL2",
                "-lSDL2_ttf",
                "-D_THREAD_SAFE"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
